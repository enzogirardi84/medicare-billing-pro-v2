# ── Database (PostgreSQL Supabase o SQLite fallback) ──
# Formato Supabase: postgresql://postgres:PASSWORD@db.HOST.supabase.co:5432/postgres
# Dejar vacio para usar SQLite local.
DATABASE_URL=
SQLITE_PATH=./billing_pro.db

# ── Supabase ──
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx

# ── ARCA (Facturacion Electronica) ──
ARCA_HOMOLOGACION=true
ARCA_CUIT=00000000000
ARCA_CERT_PATH=./certs/certificado.crt
ARCA_KEY_PATH=./certs/clave_privada.key
ARCA_PUNTO_VENTA=1
ARCA_TIPO_COMPROBANTE=11

# ── API Key legacy (tambien soporta JWT) ──
BILLING_API_KEY=tu-api-key-segura

# ── JWT ──
JWT_SECRET=cambia-esto-en-produccion-2026
JWT_EXPIRE_HOURS=24
